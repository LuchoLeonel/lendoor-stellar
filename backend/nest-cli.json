{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "entryFile": "src/main",
    "assets": [
      { "include": "admin/resources/**/*", "outDir": "dist/src", "watchAssets": false }
    ]
  }
}
