# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── PostgreSQL (REQUIRED) ──────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lendoor
POSTGRES_PASSWORD=
POSTGRES_DB=lendoor_database
POSTGRES_SSL=false
# POSTGRES_SSL_CA=            # Optional: path to CA cert for strict SSL verification
# POSTGRES_SSL_STRICT=false   # Set to 'true' to enforce cert validation without a CA file

# ── Redis (defaults to localhost) ──────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Blockchain (REQUIRED) ──────────────────────────────
ETH_RPC_URL=
ETH_LOAN_MANAGER=0x0000000000000000000000000000000000000000
ETH_PRIVATE_KEY=

# ── SMTP / Email (optional — gracefully degrades) ──────
SMTP_USER=
SMTP_APP_PASS=
SMTP_SENDER=

# ── Kapso WhatsApp (optional — https://kapso.ai) ───────
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
WA_TPL_LANG=es

# ── Meta WhatsApp templates (optional) ─────────────────
WA_TPL_DUE_3D=
WA_TPL_DUE_TOMORROW=
WA_TPL_DUE_TODAY=
WA_TPL_OVERDUE=

# Spec 064 — Meta WA template `repayment_link` (aprobado por Lucho 18/5).
# Body: 2 vars [{{1}}=monto USDC con 2 decimales, {{2}}=fecha vencimiento humana ej "23 de mayo de 2026"]
# Botón: CTA URL ESTÁTICA → LENDOOR_REPAY_URL
WA_TPL_PAYMENT_LINK=repayment_link
WA_TPL_PAYMENT_LINK_LANG=es_AR

# Spec 064 — URL estática del frontend a donde apunta el botón "Pagar" del template WA.
# Default: ${FRONTEND_URL}/repay
LENDOOR_REPAY_URL=https://app.lendoor.xyz/repay

# Spec 064 — Voice-agent → backend shared API key (header X-Voice-Agent-Key).
# MUST be a long random string. Same value goes in voice-agent .env as LENDOOR_AGENT_API_KEY.
VOICE_AGENT_API_KEY=

# ── Self.xyz verification (REQUIRED) ───────────────────
SELF_SCOPE=lendoor-dev
BACKEND_URL=http://localhost:5000
SELF_MOCK_PASSPORT=false   # NEVER set to 'true' in production

# ── Waitlist ───────────────────────────────────────────
USER_UNTIL_WAITLIST=100
WAITLIST_RELEASE_PAUSED=false
# Spec 056 — pause the "you're admitted" email notifier independently
# from slot growth. Set 'true' during waitlist re-scoring runs.
EARLY_ACCESS_NOTIFIER_PAUSED=false

# ── App URLs ───────────────────────────────────────────
LENDOOR_APP_URL=https://lendoor.xyz
LENDOOR_UNSUBSCRIBE_URL=

# ── Alerting ───────────────────────────────────────────
ALERT_PHONE=            # Phone number for critical alerts (E.164 format)
RISK_ALERT_PHONE=       # Phone for risk model alerts (E.164, falls back to ALERT_PHONE)

# ── Logging / Monitoring ───────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# ── Risk Model (optional — gracefully degrades) ───────
RISK_API_URL=http://risk-api:8000
RISK_API_KEY=
RISK_SCORING_ENABLED=false
RISK_API_TIMEOUT_MS=10000

# ── Contract tuning (safe defaults) ────────────────────
CLM_AUTO_CLEAR_PENDING_NONCES=true
CLM_AUTO_CLEAR_MAX_STEPS=500
CLM_TX_CONFIRM_TIMEOUT_MS=60000
CLM_CANCEL_CONFIRM_TIMEOUT_MS=60000
CLM_CANCEL_FEE_MULTIPLIER=4
CLM_CANCEL_FEE_MULTIPLIER_STEP=2
CLM_MIN_PRIORITY_FEE_WEI=2000000000

# ── AI draft generation — Email Operator Dashboard (spec 082 Phase 3) ──
# Provider switch: 'bedrock' (default) or 'anthropic'.
EMAIL_DRAFT_PROVIDER=bedrock
# Model override. Defaults per provider:
#   bedrock:    us.anthropic.claude-haiku-4-5-20251001-v1:0  (same inference profile as voice-agent)
#   anthropic:  claude-sonnet-4-6
EMAIL_DRAFT_MODEL=

# AWS credentials for Bedrock (provider=bedrock, default).
# AWS_BEARER_TOKEN_BEDROCK is the SAME Bedrock token already used by the voice-agent.
# AWS_REGION defaults to us-east-1 if unset.
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=

# Anthropic direct API key — only required when EMAIL_DRAFT_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# ── Zoho Mail IMAP/SMTP — Email Operator Dashboard (spec 082) ──────────
# Phase 1: inbound sync via IMAP (imapflow). App-specific password required.
# If unset, the sync is disabled at startup (graceful degradation, no crash).
ZOHO_IMAP_HOST=imap.zoho.com
ZOHO_IMAP_PORT=993
ZOHO_MAIL_USER=                # e.g. admin@lendoor.xyz
ZOHO_MAIL_APP_PASSWORD=        # Zoho app-specific password (not your account password)
# Phase 2: outbound replies via SMTP (nodemailer). Same credentials as above.
# Port 465 = TLS (secure:true). Change only if using a non-standard Zoho endpoint.
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
