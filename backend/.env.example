# Lendoor Stellar — backend env template.
# Copy to `.env` and fill in. NEVER put real/production credentials here.
# Values below are safe placeholders / public testnet defaults only.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000

# ── Database (Postgres) ──────────────────────────────────────────────────────
# Use DATABASE_URL OR the discrete POSTGRES_* vars.
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lendoor
POSTGRES_PASSWORD=
POSTGRES_DB=lendoor_stellar
POSTGRES_SSL=false
# Only if connecting to a managed PG over TLS:
POSTGRES_SSL_CA=
POSTGRES_SSL_STRICT=false

# ── Stellar / Soroban (the chain layer) ──────────────────────────────────────
# These replace the old EVM vars (ETH_RPC_URL / ETH_PRIVATE_KEY / ETH_LOAN_MANAGER)
# during the migration. See contratos/MIGRATION_EVM_TO_SOROBAN.md §1.2.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Secret seed (S...) of the operator account = the contracts' owner. SECRET — leave empty here.
STELLAR_OPERATOR_SECRET=
# Deployed contract ids (C...). Fill after deploying to testnet.
SOROBAN_LOAN_MANAGER=
SOROBAN_VAULT=
# USDC Stellar Asset Contract id (C...) on the chosen network.
SOROBAN_USDC_SAC=
# Optional: Soroban RPC event-indexing cursor source (replaces the EVM subgraph).
SUBGRAPH_URL=

# ── Exchange identity (KYC leverage) ─────────────────────────────────────────
# Embedded distribution: the wallet/exchange passes verified identity claims, so
# there's no re-KYC. Live version uses Lemon's authenticate(); the Bitso/exchange
# equivalent plugs in here. For the demo this is mocked (random KYC'd identity).
LEMON_API_KEY=
LEMON_PROFILE_API_URL=

# ── Identity verification (Self.xyz) ─────────────────────────────────────────
SELF_SCOPE=lendoor-stellar-dev
# Dev-only: skip real passport verification. NEVER set to 'true' in production.
SELF_MOCK_PASSPORT=false

# ── Auth (optional) ──────────────────────────────────────────────────────────
# Comma-separated wallet addresses with elevated access (if used). Optional.
ADMIN_WALLETS=
